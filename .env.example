# OpenAI — used for both chat generation and embeddings
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Pinecone — vector database
# Get one at https://app.pinecone.io/
PINECONE_API_KEY=

# Tavily — web search fallback
# Get one at https://app.tavily.com/
TAVILY_API_KEY=

# Name of the Pinecone index (created automatically if it doesn't exist)
PINECONE_INDEX_NAME=pdf-rag
